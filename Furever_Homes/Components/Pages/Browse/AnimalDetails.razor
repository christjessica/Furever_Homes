@page "/animal-details/{animalId:int}"
@rendermode InteractiveServer

@using Furever_Homes.Models
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor
@using Furever_Homes.Services
@inject ForeverDatabaseContext DbContext
@inject NavigationManager NavigationManager
@inject CurrentUserService CurrentUser

@if (animal == null)
{
    <p>Loading animal details...</p>
}
else
{
    <RadzenCard Style="padding:20px; max-width:700px;">
        <h2>@animal.Name</h2>

        @if (photos.Any())
        {
            <div style="position:relative; margin-bottom:20px;">
                <img src="@photos[currentPhotoIndex].PhotoUrl"
                     style="width:100%; max-height:350px; object-fit:cover; border-radius:10px;" />

                @if (photos.Count > 1)
                {
                    <RadzenButton Text="‹"
                                  ButtonStyle="ButtonStyle.Light"
                                  Style="position:absolute; left:10px; top:45%;"
                                  Click="@PreviousPhoto" />

                    <RadzenButton Text="›"
                                  ButtonStyle="ButtonStyle.Light"
                                  Style="position:absolute; right:10px; top:45%;"
                                  Click="@NextPhoto" />

                    <p style="text-align:center; margin-top:5px;">
                        @(currentPhotoIndex + 1) / @photos.Count
                    </p>
                }
            </div>
        }
        else
        {
            <p style="color:gray;">No photos available.</p>
        }

        <p><b>Breed:</b> @animal.Breed?.BreedName</p>
        <p><b>Sex:</b> @animal.Sex</p>
        <p><b>Age:</b> @FormatAge(animal.Age)</p>
        <p><b>Color:</b> @animal.Color</p>
        <p><b>Vaccinated:</b> @(animal.Vaccinated ? "Yes" : "No")</p>
        <p><b>Description:</b> @animal.Description</p>

        @if (CurrentUser.IsAuthenticated && CurrentUser.UserType == "Adopter")
        {
            <RadzenButton Text="Apply to Adopt"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Small"
                          Click="@(() => NavigationManager.NavigateTo($"/application-form/{animal.AnimalId}"))" />
        }

        <RadzenButton Text="Back"
                      ButtonStyle="ButtonStyle.Light"
                      Size="ButtonSize.Small"
                      Style="margin-left:10px;"
                      Click="@(() => NavigationManager.NavigateTo("/browse-animals"))" />

    </RadzenCard>
}

@code {
    [Parameter] public int animalId { get; set; }

    private Animal? animal;

    private List<AnimalPhoto> photos = new();
    private int currentPhotoIndex = 0;

    private void NextPhoto()
    {
        if (!photos.Any()) return;

        currentPhotoIndex++;

        if (currentPhotoIndex >= photos.Count)
            currentPhotoIndex = 0;
    }

    private void PreviousPhoto()
    {
        if (!photos.Any()) return;

        currentPhotoIndex--;

        if (currentPhotoIndex < 0)
            currentPhotoIndex = photos.Count - 1;
    }

    protected override async Task OnInitializedAsync()
    {
        animal = await DbContext.Animals
            .Include(a => a.Breed)
            .Include(a => a.AnimalPhotos)
            .Include(a => a.Shelter)
            .FirstOrDefaultAsync(a => a.AnimalId == animalId);

        if (animal != null)
        {
            photos = animal.AnimalPhotos
                .OrderByDescending(p => p.IsPrimary)
                .ThenBy(p => p.PhotoId)
                .ToList();
        }
    }

    private string FormatAge(int? months)
    {
        if (months == null) return "Unknown";
        if (months < 12) return $"{months} months";

        int years = months.Value / 12;
        int remainingMonths = months.Value % 12;

        return remainingMonths == 0
            ? $"{years} years"
            : $"{years} years {remainingMonths} months";
    }
}
