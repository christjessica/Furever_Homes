@page "/adopter-dashboard"
@rendermode InteractiveServer

@using Furever_Homes.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor
@using Furever_Homes.Services

@inject Furever_Homes.Models.ForeverDatabaseContext DbContext
@inject NavigationManager NavigationManager
@inject CurrentUserService CurrentUser

<RadzenButton Text="Edit Account" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Click="EditAccount" />
<RadzenButton Text="View Saved Animals" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Click="ViewSavedAnimals" />
<RadzenButton Text="My Applications" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Click="ViewApplications" />


@code {

    protected override async Task OnInitializedAsync()
    {
        //Not logged in
        if (!CurrentUser.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/sign-in");
            return;
        }

        //Wrong user type
        if (CurrentUser.UserType != "Adopter")
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        //Safe to load adopter dashboard
        var userId = CurrentUser.UserId;

        var adopter = await DbContext.Adopters
            .FirstOrDefaultAsync(a => a.ApplicationUserId == CurrentUser.UserId);

        if (adopter == null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }
    }

    private void EditAccount()
    {
        NavigationManager.NavigateTo("/edit-account");
    }

    private void ViewSavedAnimals()
    {
        NavigationManager.NavigateTo("/adopter-dashboard/saved-animals");
    }

    private void ViewApplications()
    {
        NavigationManager.NavigateTo("/adopter-dashboard/applications");
    }
}