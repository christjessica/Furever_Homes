@page "/shelter-dashboard"
@rendermode InteractiveServer

@using Furever_Homes.Models
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor

@inject UserManager<ApplicationUser> UserManager
@inject Furever_Homes.Models.ForeverDatabaseContext DbContext
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<RadzenButton Text="Add Animal" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Click="AddAnimal"/>

@code {
    private void AddAnimal()
    {
        NavigationManager.NavigateTo("/add-animal");
    }
}
