@page "/shelter-dashboard/view-animals"
@rendermode InteractiveServer

@using Furever_Homes.Models
@using Furever_Homes.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor

@inject Furever_Homes.Models.ForeverDatabaseContext DbContext
@inject NavigationManager NavigationManager
@inject CurrentUserService CurrentUser
@inject NotificationService NotificationService

<h3>View Animals</h3>

@* Displays of the shelter's animals in a card-based layout.
   Each card shows the primary photo, basic info, and a link to edit details. *@

@* Responsive grid:
   - 1 column on small screens
   - 2 on medium
   - 3 on large *@

<RadzenButton Text="Back to Dashboard"
              ButtonStyle="ButtonStyle.Primary"
              Click="@(() => GoBack())" />

<RadzenRow Gap="1rem">
    @foreach (var a in animals)
    {
        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            @* Individual animal card *@
            <RadzenCard Style="padding:0; overflow:hidden; max-width:400px">

                @* Get the primary photo for this animal *@
                @* Because of the database constraint, there should only ever be one primary photo *@
                @{
                    var primaryPhoto = a.AnimalPhotos.FirstOrDefault(p => p.IsPrimary)?.PhotoUrl;
                }

                @* Show image if available, otherwise show placeholder *@
                @if (!string.IsNullOrWhiteSpace(primaryPhoto))
                {
                    <img src="@primaryPhoto"
                         style="width:100%; height:220px; object-fit:cover" />
                }
                else
                {
                    <div style="width:100%;
                                        height:220px;
                                        background-color:#eee;
                                        display:flex;
                                        align-items:center;
                                        justify-content:center">
                        <span style="color:#888;">No Photo Available</span>
                    </div>
                }

                @* Animal basic info: name, sex, age, breed *@
                <div style="padding:15px">

                    <!-- Name -->
                    <h3 style="margin-bottom:5px">@a.Name</h3>

                    <!-- Subtitle -->
                    <p style="margin:0; color:gray;">
                        @a.Sex • @FormatAge(a.Age) • @a.Breed?.BreedName
                    </p>

                    @* Navigate to full details page for this animal *@
                    <RadzenButton Text="Edit ✏️"
                                  Style="margin-top:10px"
                                  Click="@(() => GoToEdit(a.AnimalId))" />
                </div>
            </RadzenCard>
        </RadzenColumn>
    }
</RadzenRow>

@code {
    // Holds all animals displayed on the page
    private List<Animal> animals = new();

    // Loads shelter's animals from the database,
    // including related data (breed, photos, shelter)
    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.IsAuthenticated || CurrentUser.UserType != "Shelter")
        {
            NavigationManager.NavigateTo("/sign-in");
            return;
        }

        var shelter = await DbContext.Shelters
            .FirstOrDefaultAsync(s => s.ApplicationUserId == CurrentUser.UserId);

        if (shelter == null)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Shelter not found",
                Detail = "Could not find a shelter profile for this account."
            });

            NavigationManager.NavigateTo("/shelter-dashboard");
            return;
        }

        animals = await DbContext.Animals
            .Include(a => a.Breed)
            .Include(a => a.AnimalPhotos)
            .Where(a => a.ShelterId == shelter.ShelterId)
            .ToListAsync();
    }

    // Converts total months into readable format (years/months)
    private string FormatAge(int? months)
    {
        if (months == null) return "Unknown";
        if (months < 12) return $"{months} months";

        int years = months.Value / 12;
        int remainingMonths = months.Value % 12;

        return remainingMonths == 0
            ? $"{years} years"
            : $"{years} years {remainingMonths} months";
    }

    // Navigates to the details page for the selected animal
    void GoToEdit(int animalId)
    {
        NavigationManager.NavigateTo($"/shelter-dashboard/edit-animal/{animalId}");
    }

    void GoBack()
    {
        NavigationManager.NavigateTo("/shelter-dashboard");
    }
}
