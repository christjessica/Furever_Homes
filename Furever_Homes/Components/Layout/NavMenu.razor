@using Furever_Homes.Services
@inject CurrentUserService CurrentUser

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Furever Homes</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="browse-animals">
                <span class="bi bi-search-nav-menu" aria-hidden="true"></span>
                Browse Animals
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="edit-account">
                <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                Edit Account
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@GetDashboardRoute()">
                <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span>
                Dashboard
            </NavLink>
        </div>

    </nav>
</div>

@code {
    private string GetDashboardRoute()
    {
        if (!CurrentUser.IsAuthenticated)
            return "/sign-in";

        return CurrentUser.UserType switch
        {
            "Adopter" => "/adopter-dashboard",
            "Shelter" => "/shelter-dashboard",
            _ => "/"
        };
    }
}